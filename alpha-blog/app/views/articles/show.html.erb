<div class="page-container p-3">
  <div class="container">
    <h1><%= @article.title %></h1>

    <div class="card text-center shadow rounded">
      <div class="card-header">
        by Rubeen
      </div>
      <div class="card-body">
        <h5 class="card-title"><%= link_to @article.title, @article, class: 'text-primary' %></h5>
        <p class="card-text"><%= simple_format(@article.description) %></p>
        <div class="btn-group" role="group" aria-label="Basic example">
          <%= link_to 'Edit', edit_article_path(@article), class: 'btn btn-outline-warning' %>
          <%= link_to 'Delete', article_path(@article), class: 'btn btn-outline-danger', method: :delete, data: {confirm: 'are you sure?'} %>
        </div>
      </div>
      <div class="card-footer text-muted">
        Created <%= time_ago_in_words(@article.created_at) %> hour ago,
        edited <%= time_ago_in_words(@article.updated_at) %> hour ago
      </div>
    </div>
  </div>
</div>

